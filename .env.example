DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/researchswarm
LOG_LEVEL=INFO
# JSON application logs: {LOG_DIRECTORY}/backend.jsonl (default logs/ under cwd)
LOG_DIRECTORY=logs

# Agent layer (LLM + LangGraph)
GOOGLE_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
MAX_ITERATIONS=3
GRAPH_TIMEOUT_SECONDS=60
REGISTRY_BASE_URL=http://localhost:8000

# Dynamic tool binding (ToolDiscoveryTool)
TOOL_INVOCATION_TIMEOUT_SECONDS=30
MAX_TOOL_FALLBACK_ATTEMPTS=3

LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Conversation layer (optional; all keys prefixed CONVERSATION_ in code)
# CONVERSATION_LLM_MODEL=gemini-2.5-flash-lite
