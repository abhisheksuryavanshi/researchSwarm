DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/researchswarm
LOG_LEVEL=INFO
# JSON application logs: {LOG_DIRECTORY}/backend.jsonl (default logs/ under cwd)
LOG_DIRECTORY=logs

# Agent layer (LLM + LangGraph)
# Providers: groq | google | ollama (local). For Ollama: `ollama pull llama3.1:8b` then run `ollama serve`.
LLM_PROVIDER=groq
GROQ_API_KEY=
LLM_MODEL=llama-3.1-8b-instant
# Local Ollama (when LLM_PROVIDER=ollama); LLM_MODEL e.g. llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
GOOGLE_API_KEY=
LLM_TEMPERATURE=0.1
# Local models may need higher values (e.g. 120–300).
LLM_TIMEOUT_SECONDS=30
# One API attempt per LLM invoke when false (reduces 429s). Set true when stable.
LLM_RETRIES_ENABLED=false
# Used only when LLM_RETRIES_ENABLED=true (passed to the chat model max_retries).
LLM_MAX_RETRIES=3
MAX_ITERATIONS=3
GRAPH_TIMEOUT_SECONDS=60
REGISTRY_BASE_URL=http://localhost:8000

# Dynamic tool binding (ToolDiscoveryTool)
TOOL_INVOCATION_TIMEOUT_SECONDS=30
MAX_TOOL_FALLBACK_ATTEMPTS=3

LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Browser UI (comma-separated origins for CORSMiddleware). Include both hostname styles.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Conversation layer (optional; all keys prefixed CONVERSATION_ in code)
# CONVERSATION_LLM_MODEL=llama-3.1-8b-instant
